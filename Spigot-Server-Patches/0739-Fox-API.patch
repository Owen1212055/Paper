Subject: [PATCH] Fox API


diff --git a/src/main/java/org/bukkit/craftbukkit/entity/CraftFox.java b/src/main/java/org/bukkit/craftbukkit/entity/CraftFox.java
index 362ac8e43096995184c2d13ccdd69a84103a791c..b4a1b1bc1678b7380e438ab94c28f37e77e240ce 100644
--- a/src/main/java/org/bukkit/craftbukkit/entity/CraftFox.java
+++ b/src/main/java/org/bukkit/craftbukkit/entity/CraftFox.java
@@ -115,4 +115,45 @@ public class CraftFox extends CraftAnimals implements Fox {
 
         getHandle().getDataWatcher().set(EntityFox.SECOND_TRUSTED_PLAYER, player == null ? Optional.empty() : Optional.of(player.getUniqueId()));
     }
+    // Paper start - Add more fox behavior API
+    @Override
+    public void setHeadTilted(boolean tilted) {
+        getHandle().setHeadTilted(tilted);
+    }
+
+    @Override
+    public boolean isHeadTilted() {
+        return getHandle().isHeadTilted();
+    }
+
+    @Override
+    public void setLeaping(boolean leaping) {
+        getHandle().setLeaping(leaping);
+    }
+
+    @Override
+    public boolean isLeaping() {
+        return getHandle().isLeaping();
+    }
+
+    @Override
+    public void setAngry(boolean angry) {
+        getHandle().setAngry(angry);
+    }
+
+    @Override
+    public boolean isAngry() {
+        return getHandle().isAngry();
+    }
+
+    @Override
+    public void setWalking(boolean walking) {
+        getHandle().setWalking(walking);
+    }
+
+    @Override
+    public boolean isWalking() {
+        return getHandle().isWalking();
+    }
+    // Paper end - Add more fox behavior API
 }
